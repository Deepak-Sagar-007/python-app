pipeline {
    agent any

    stages {
        stage('Start') {
            steps {
                echo "Jenkins Pipeline Triggered 🚀"
            }
        }

        stage('Build') {
            steps {
                echo "Building Project..."
            }
        }

        stage('Test') {
            steps {
                echo "Running Tests..."
            }
        }

        stage('Finish') {
            steps {
                echo "Pipeline Completed ✅"
            }
        }
    }
}